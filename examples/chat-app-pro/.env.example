# Anthropic API key — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Optional — Claude model. Defaults to claude-sonnet-4-6 for cost/latency balance.
ANTHROPIC_MODEL=claude-sonnet-4-6

# Neon Postgres connection string (pooled). The app uses the PGBouncer-pooled
# endpoint for reads/writes. Do NOT commit this file with real credentials.
DATABASE_URL=postgresql://user:password@ep-your-host-pooler.region.aws.neon.tech/neondb?sslmode=require

# Backend port (Vite dev server proxies /api/* here).
PORT=3031

# Where PSON writes transient session state (JSON files) — the PROFILES
# themselves go to Postgres via the adapter, but learning-session state
# is still filesystem for now.
PSON_SESSION_DIR=./data

# Optional — log every PSON tool call to stdout.
CHAT_APP_LOG_TOOLS=false

# Required for the generative flow (Claude inventing questions).
# Reuses the ANTHROPIC_API_KEY above — this just turns the flow ON.
PSON_AI_PROVIDER=anthropic
PSON_AI_MODEL=claude-sonnet-4-6
