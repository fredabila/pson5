# Anthropic API key — required. https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Where PSON5 stores the persona profile. Isolated from the parent monorepo
# so this demo can't interfere with any real profiles.
PSON_STORE_DIR=./store

# The persona's user_id inside PSON. Shared across all sessions — every run
# with this same user_id deepens the same persona.
PERSONA_USER_ID=persona_amelia_kwan_v1
