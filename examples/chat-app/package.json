{
  "name": "@pson5/example-chat-app",
  "version": "0.1.0",
  "private": true,
  "description": "Reference chatbot combining Anthropic Claude with the PSON5 SDK. Claude gets the PSON agent tools and reasons over a per-session profile; the UI shows the three-layer model in real time.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n server,web -c magenta,cyan \"npm run dev:server\" \"npm run dev:web\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:web": "vite --config web/vite.config.ts",
    "build": "npm run build:web && npm run build:server",
    "build:server": "tsc -p server/tsconfig.json",
    "build:web": "vite build --config web/vite.config.ts",
    "start": "node dist/server/index.js",
    "check": "tsc -p server/tsconfig.json --noEmit && tsc -p web/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "@pson5/sdk": "0.2.0",
    "@pson5/core-types": "0.2.0",
    "@pson5/serialization-engine": "0.2.0",
    "@pson5/provider-engine": "0.2.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vite": "^5.4.0"
  },
  "engines": {
    "node": ">=20"
  }
}
