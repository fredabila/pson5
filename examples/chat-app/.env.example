# Anthropic API key — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Claude model. Sonnet 4.6 is the default; Haiku 4.5 is fastest/cheapest.
ANTHROPIC_MODEL=claude-sonnet-4-6

# Where the server listens for the API (separate from Vite's dev port).
PORT=3030

# Where PSON5 persists profiles on disk. Gets created on first run.
PSON_STORE_DIR=.pson5-store

# Optional — set to true to log every Claude tool call on the server.
CHAT_APP_LOG_TOOLS=false
