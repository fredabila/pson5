{
  "name": "@pson5/serialization-engine",
  "version": "0.2.0",
  "description": "Profile initialization, import/export, storage adapters, and persistence helpers for PSON5.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fredabila/pson5.git",
    "directory": "packages/serialization-engine"
  },
  "homepage": "https://github.com/fredabila/pson5/tree/main/packages/serialization-engine#readme",
  "bugs": {
    "url": "https://github.com/fredabila/pson5/issues"
  },
  "type": "module",
  "main": "./dist/serialization-engine/src/index.js",
  "types": "./dist/serialization-engine/src/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/serialization-engine/src/index.d.ts",
      "default": "./dist/serialization-engine/src/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "pson",
    "serialization",
    "storage",
    "profiles",
    "import",
    "export"
  ],
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@pson5/core-types": "0.2.0",
    "@pson5/privacy": "0.2.0",
    "@pson5/schemas": "0.2.0"
  }
}
