{
  "name": "@pson5/postgres-store",
  "version": "0.2.0",
  "description": "Postgres-oriented repository and schema helpers for PSON5 storage backends.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fredabila/pson5.git",
    "directory": "packages/postgres-store"
  },
  "homepage": "https://github.com/fredabila/pson5/tree/main/packages/postgres-store#readme",
  "bugs": {
    "url": "https://github.com/fredabila/pson5/issues"
  },
  "type": "module",
  "main": "./dist/postgres-store/src/index.js",
  "types": "./dist/postgres-store/src/index.d.ts",
  "files": [
    "dist",
    "sql",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/postgres-store/src/index.d.ts",
      "default": "./dist/postgres-store/src/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "pson",
    "postgres",
    "storage",
    "repository"
  ],
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@pson5/core-types": "0.2.0",
    "@pson5/serialization-engine": "0.2.0"
  }
}
