{
  "name": "@pson5/cli",
  "version": "0.2.0",
  "description": "Interactive command-line interface for PSON5 profiles, learning, simulation, and inspection.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fredabila/pson5.git",
    "directory": "apps/cli"
  },
  "homepage": "https://github.com/fredabila/pson5/tree/main/apps/cli#readme",
  "bugs": {
    "url": "https://github.com/fredabila/pson5/issues"
  },
  "type": "module",
  "bin": {
    "pson": "dist/apps/cli/src/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "dev": "node --enable-source-maps dist/apps/cli/src/index.js"
  },
  "keywords": [
    "pson",
    "cli",
    "agents",
    "personalization"
  ],
  "engines": {
    "node": ">=22"
  },
  "preferGlobal": true,
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@pson5/acquisition-engine": "0.2.0",
    "@pson5/agent-context": "0.2.0",
    "@pson5/core-types": "0.2.0",
    "@pson5/graph-engine": "0.2.0",
    "@pson5/neo4j-store": "0.2.0",
    "@pson5/provider-engine": "0.2.0",
    "@pson5/serialization-engine": "0.2.0",
    "@pson5/sdk": "0.2.0",
    "@pson5/simulation-engine": "0.2.0",
    "@pson5/state-engine": "0.2.0",
    "@types/react": "^19.2.14",
    "chalk": "^5.6.2",
    "ink": "^7.0.1",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.5"
  }
}
